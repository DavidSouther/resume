{
  "name": "@davidsouther/resume",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "check": "npm run typecheck && biome check src vitest.config.ts",
    "format": "biome format --write src vitest.config.ts",
    "lint": "biome lint --write src vitest.config.ts",
    "prebuild": "npm run check",
    "build": "next build",
    "postbuild": "echo 'davidsouther.com' > docs/CNAME && touch docs/.nojekyll",
    "start": "next start",
    "test": "vitest run",
    "posttest": "npm run check",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@davidsouther/jiffdown": "file:../../jefri/jiffdown",
    "@davidsouther/jiffies": "^2.0.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.16",
    "@vitejs/plugin-react": "^6.0.2",
    "gray-matter": "4.0.3",
    "jsdom": "^29.1.1",
    "next": "^16.2.7",
    "nextjs-google-analytics": "2.3.7",
    "react": "^19.2.7",
    "smol-toml": "^1.6.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "@biomejs/biome": "^2.4.16",
    "react-dom": "^19.2.7"
  }
}
