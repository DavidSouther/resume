{
  "name": "@davidsouther/resume",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run css:bundle && node node_modules/@davidsouther/jiffies/lib/esm/ssg/main.js --out docs --no-clean",
    "css:bundle": "lightningcss src/global.css -o public/global.css",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && biome check src pages scripts vitest.config.ts",
    "format": "biome format --write src pages scripts vitest.config.ts",
    "lint": "biome lint --write src pages scripts vitest.config.ts",
    "prebuild": "npm run check",
    "build": "npm run css:bundle && node scripts/sitemap.ts && node node_modules/@davidsouther/jiffies/lib/esm/ssg/main.js --out docs",
    "start": "node scripts/serve.ts --watch",
    "test": "vitest run",
    "posttest": "npm run check",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@davidsouther/jiffdown": "^2026.24.0",
    "@davidsouther/jiffies": "^2026.25.0",
    "@testing-library/dom": "^10.4.1",
    "@types/node": "^24.12.4",
    "gray-matter": "4.0.3",
    "jsdom": "^29.1.1",
    "lightningcss-cli": "^1.30.2",
    "smol-toml": "^1.6.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "@biomejs/biome": "^2.4.16"
  }
}
